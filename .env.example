APP_NAME=sna-demo-app
PORT=8000

POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DB_CONNECT_RETRIES=20
DB_CONNECT_DELAY=2
DB_POOL_MAX_SIZE=10

NGINX_HTTP_PORT=80
NGINX_EXPORTER_PORT=9113

LOAD_DURATION=120
LOAD_CONCURRENCY=20
LOAD_INTERVAL=0.05
LOAD_WRITE_RATIO=0.35
LOAD_TIMEOUT=5
LOADTEST_TARGET_URL=http://nginx
